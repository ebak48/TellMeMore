# ── REQUIRED ─────────────────────────────────────────────────────────────────
ADMIN_PASS=change-me-before-deploy
BASE_URL=https://tellmemore-production.up.railway.app

# ── REQUIRED BEFORE SOFT LAUNCH ──────────────────────────────────────────────
# Without this: magic links are returned in the API response body (alpha only)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ── OPTIONAL ─────────────────────────────────────────────────────────────────
# Railway sets PORT automatically. Only set locally.
# PORT=3000

# Salt for IP hashing in rate limiter. Auto-generated on restart without this.
# Set it to persist rate-limit keys across restarts.
# IP_SALT=any-random-secret-string

# Railway sets this automatically when a volume is mounted at /app/data
# RAILWAY_VOLUME_MOUNT_PATH=/app/data
