# ─── REQUIRED ────────────────────────────────────────────────────────────────
# Admin dashboard password (change before deploy — default is weak)
ADMIN_PASS=change-me-before-deploy

# Public base URL of the app (used in magic links and share URLs)
BASE_URL=https://tellmemore-production.up.railway.app

# ─── REQUIRED BEFORE SOFT LAUNCH (optional for alpha) ────────────────────────
# Resend API key for sending magic login emails
# Without this, alpha mode returns the magic link in the API response body.
# Set this before giving access to users who are not monitoring the server logs.
RESEND_API_KEY=re_xxxxxxxxxxxx

# ─── OPTIONAL ────────────────────────────────────────────────────────────────
# Railway sets PORT automatically. Only set locally.
# PORT=3000

# Railway volume mount path (default: /app/data)
# RAILWAY_VOLUME_MOUNT_PATH=/app/data

# Salt for IP hashing (auto-generated on start if not set — changes on restart)
# IP_SALT=random-secret-here
